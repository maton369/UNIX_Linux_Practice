/* stdio/diary1.c */
#include <stdio.h>      /* clearerr, fclose, feof, ferror,
                           fgets, fopen, fputs, perror, stdin, stdout, stderr */
#include <stdlib.h>     /* exit */
#include "mysub.h"

/*
 * このコードの主題は「ストリームのエラー処理」である。
 *
 * ここでいうストリームとは、stdio が扱う FILE * 型の入出力対象のことである。
 * 例えば
 *
 *   - stdin   : 標準入力
 *   - stdout  : 標準出力
 *   - ファイルを fopen() で開いた FILE *
 *
 * などがストリームである。
 *
 * このプログラムは、簡易的な「日記プログラム」であり、
 *
 *   1 = 日記を書く
 *   2 = 日記を読む
 *   3 = 終了
 *
 * という3つの機能を持つ。
 *
 * ただし、このコードで本当に学ぶべき重要点は、
 *   「fgets() が NULL を返したとき、その理由は EOF なのかエラーなのか」
 * をストリーム状態で見分けることにある。
 *
 * stdio の入力関数 fgets() は、
 *   - 正常に1行読めたとき     -> バッファへのポインタを返す
 *   - EOF に達したとき       -> NULL を返す
 *   - エラーが起きたとき     -> NULL を返す
 * という振る舞いをする。
 *
 * つまり「NULL を返した」という事実だけでは、
 *   もう正常に終端まで読んだのか
 *   途中で異常が起きたのか
 * が分からない。
 *
 * そこで使うのが次の関数である。
 *
 *   feof(stream)
 *     -> EOF フラグが立っているか調べる
 *
 *   ferror(stream)
 *     -> エラーフラグが立っているか調べる
 *
 *   clearerr(stream)
 *     -> EOF フラグやエラーフラグをクリアする
 *
 * このコードは、それらを実際に使って
 * 「入力終了」と「入出力異常」を区別している教材である。
 */

/*
 * 1行バッファの最大長。
 *
 * fgets() で使うバッファサイズとして 1024 を採用している。
 * したがって、1回の fgets() で読み込めるのは
 *
 *   最大 1023 文字 + 終端 '\0'
 *
 * である。
 */
enum {
    MAXLINE = 1024,
};

/*
 * 先に関数プロトタイプ宣言を書いている。
 *
 * writediary():
 *   標準入力から日記本文を受け取り、指定ファイルへ保存する。
 *
 * readdiary():
 *   指定ファイルを開いて内容を読み、標準出力へ表示する。
 */
void writediary(void);
void readdiary(void);

int main(void) {
    /*
     * cmd:
     *   ユーザが入力したメニュー番号を保持する。
     *
     * getint() は mysub.h / mysub.c 側で定義されている補助関数で、
     * プロンプトを表示して整数入力を受け取るものだと考えられる。
     */
    int cmd;

    /*
     * for (;;) は無限ループである。
     *
     * このプログラムはメニュー型の対話プログラムなので、
     * ユーザが 3 を選ぶまで何度でも
     *
     *   書く
     *   読む
     *
     * を繰り返せるようになっている。
     */
    for (;;) {
        /*
         * メニューを表示してコマンド番号を読む。
         *
         * 期待する値:
         *   1 -> 書く
         *   2 -> 読む
         *   3 -> 終了
         */
        cmd = getint("1=write, 2=read, 3=end: ");

        /*
         * 読み取った cmd に応じて処理を分岐する。
         */
        switch (cmd) {
            case 1:
                /*
                 * 日記を書き込むモードへ入る。
                 */
                writediary();
                break;

            case 2:
                /*
                 * 日記を読み出すモードへ入る。
                 */
                readdiary();
                break;

            case 3:
                /*
                 * 正常終了。
                 *
                 * 無限ループを抜ける代わりに、ここで main から return する。
                 */
                return 0;

            default:
                /*
                 * 1,2,3 以外が入力された場合のエラー表示。
                 *
                 * これはストリームエラーではなく、単なるコマンド入力値の不正である。
                 * そのため stderr に診断メッセージを出して再度メニューへ戻る。
                 */
                fputs("unknown command\n", stderr);
                break;
        }
    }
}

/*
 * writediary:
 *   標準入力から複数行の日記本文を読み取り、
 *   指定した日付名のファイルへ書き込む関数である。
 *
 * 全体のアルゴリズム:
 *
 *   1. 日付文字列を入力してもらう
 *   2. その日付名で書き込み用ファイルを開く
 *   3. stdin から fgets() で1行ずつ読む
 *   4. 読んだ行を fputs() でファイルへ書く
 *   5. fgets() が NULL を返したら、原因が EOF かエラーか調べる
 *   6. EOF なら clearerr(stdin) して入力ストリームを再利用可能に戻す
 *   7. エラーなら perror して終了
 *   8. ファイルを閉じる
 *
 * この関数で最も重要なのは、
 *   fgets(..., stdin) が終わった後に feof(stdin) を見ている点
 * と、
 *   EOF に達した stdin に対して clearerr(stdin) している点
 * である。
 */
void writediary(void) {
    /*
     * fp:
     *   書き込み先の日記ファイルを表す FILE * である。
     *
     * ここへは
     *   fopen(date, "w")
     * の戻り値が入る。
     *
     * "w" モードなので、
     *   - ファイルが無ければ新規作成
     *   - 既存なら中身を空にして上書き
     * となる。
     */
    FILE *fp;

    /*
     * date:
     *   ユーザが入力する日付文字列（例: "0825" など）を入れるバッファ。
     *
     * この文字列がそのままファイル名として使われる。
     *
     * s:
     *   stdin から1行ずつ読み込んだ日記本文を保持するバッファ。
     *
     * fgets() で1行ずつここへ入り、fputs() で fp へ書かれる。
     */
    char date[MAXLINE], s[MAXLINE];

    /*
     * getstr() で日付を文字列として受け取る。
     *
     * 想定としては "MMDD" 形式（例: 0825）だが、
     * このコード自体は文字列の内容検証をしていない。
     *
     * 入力された date がそのままファイル名になるので、
     * 例えば "0825" ならファイル "0825" が作られる。
     */
    getstr("date (MMDD): ", date, sizeof(date));

    /*
     * 指定された日付名で出力ファイルを開く。
     *
     * "w" モードなので、その日付の日記ファイルを書き込む準備をする。
     *
     * 重要:
     *   元コードでは fopen の失敗チェックが無い。
     *   実務的には
     *
     *     if ((fp = fopen(date, "w")) == NULL) { ... }
     *
     * のように NULL チェックが必要である。
     *
     * ただしこの教材の主題は主に fgets 終了後のストリーム状態確認なので、
     * ここでは元コードの意図に沿って説明する。
     */
    fp = fopen(date, "w");

    /*
     * while (fgets(s, sizeof(s), stdin) != NULL)
     *
     * 標準入力 stdin から1行ずつ読むループである。
     *
     * fgets() は
     *   - 1行読めたら s を返す
     *   - EOF またはエラーなら NULL を返す
     * ので、
     *
     *   「NULL でない間は読めている」
     *
     * という条件でループしている。
     *
     * このループでは stdin から読んだ行を、そのまま fp へ書き出す。
     *
     * したがって動作としては
     *
     *   stdin ----1行読む----> s ----1行書く----> fp
     *
     * という中継処理である。
     *
     * ここで stdin から何を入力すれば終わるか:
 *   一般に端末からは EOF を入力する。
     *   典型的には
     *
     *   - UNIX/Linux 端末: Ctrl-D
     *
     * が EOF 入力になる。
     *
     * つまり、この関数では
     *   ユーザが Ctrl-D を押すまで日記本文を受け取り続ける
     * ことになる。
     */
    while (fgets(s, sizeof(s), stdin) != NULL) {
        /*
         * 読めた1行をそのまま日記ファイルへ書く。
         *
         * fgets() は改行 '\n' があればそれも含めて読むので、
         * fputs() でそのまま出力すれば、入力した行構造を保ったまま保存できる。
         *
         * 重要:
         *   元コードでは fputs() の戻り値をチェックしていない。
         *   実務的には EOF を返したらエラー処理をした方がよい。
         *
         * ここでも教材の主題は stdin 側ストリームの EOF / error 判定である。
         */
        fputs(s, fp);
    }

    /*
     * ここへ来るのは fgets(stdin) が NULL を返したときである。
     *
     * しかし fgets() が NULL を返した理由は 2 つありうる。
     *
     *   1. stdin が EOF に達した
     *   2. stdin に読み込みエラーが起きた
     *
     * その区別をするために、ストリーム状態を調べる。
     */

    if (feof(stdin)) { /* EOFか? */
        /*
         * feof(stdin)
         *
         * stdin に EOF フラグが立っているかを調べる。
         *
         * ここが true なら、
         *   fgets() が止まった理由は「入力終端（EOF）」である
         * と分かる。
         *
         * このプログラムでは、日記入力終了のために
         * ユーザが Ctrl-D を押すことを正常な終了方法として使っている。
         *
         * つまりここは異常ではなく、
         *   「本文入力をユーザが終えた」
         * と解釈する。
         */

        /*
         * clearerr(stdin)
         *
         * これがこのコードで非常に重要な処理である。
         *
         * stdin に EOF フラグが立ったままだと、
         * その後に main ループへ戻っても、次の getint() や getstr() が
         * 期待通りに入力を読めなくなる可能性がある。
         *
         * なぜなら stdio のストリームは、
         * EOF に達するとその状態を内部に記録し続けるからである。
         *
         * そこで clearerr(stdin) により、
         *   - EOF フラグ
         *   - エラーフラグ
         * をクリアし、
         * stdin を再び通常の入力に使える状態へ戻している。
         *
         * つまりこの1行は、
         *   「本文入力の終わりとして EOF を使ったあと、
         *    そのストリーム状態をリセットして次の対話入力を可能にする」
         * 処理である。
         *
         * このプログラムが対話型メニューへ戻って再利用できるのは、
         * ここで clearerr(stdin) しているからである。
         */
        clearerr(stdin);

    } else {           /* エラー */
        /*
         * feof(stdin) が偽であるにもかかわらず fgets() が NULL を返したなら、
         * それは EOF ではなく読み込みエラーだと判断している。
         *
         * この場合は正常な本文終了ではないので、異常として扱う。
         *
         * perror("fgets") は errno ベースの診断を出す。
         * stdio エラーでは errno が必ず意味あるとは限らないが、
         * 教材としては「fgets に失敗した」と示す意図で使っている。
         */
        perror("fgets");
        exit(1);
    }

    /*
     * 日記ファイルを閉じる。
     *
     * fclose(fp) によって
     *   - 出力バッファが必要なら flush される
     *   - ストリーム資源が解放される
     *
     * 元コードでは戻り値チェックが省略されているが、
     * 出力ストリームでは fclose 時に書き込み失敗が発覚することもあるため、
     * 厳密には確認した方がよい。
     */
    fclose(fp);
}

/*
 * readdiary:
 *   指定された日付ファイルを開き、その内容を1行ずつ標準出力へ表示する。
 *
 * 全体のアルゴリズム:
 *
 *   1. 日付文字列を入力してもらう
 *   2. その日付名のファイルを読み込み用で開く
 *   3. fp から fgets() で1行ずつ読む
 *   4. 読んだ1行を stdout へ fputs() する
 *   5. fgets() が NULL を返したら終了理由を調べる
 *   6. ferror(fp) が立っていれば読み込みエラー
 *   7. エラーでなければ通常の EOF 到達とみなす
 *   8. ファイルを閉じる
 *
 * writediary() との対比が重要である。
 *
 *   - writediary() では stdin を読んでいるので feof(stdin) を調べた
 *   - readdiary() ではファイル fp を読んでいるので ferror(fp) を調べている
 *
 * 特に readdiary() では、
 *   「ファイル読み終わりは普通のことなので、EOF 自体はエラー扱いしない」
 * という考え方が見える。
 */
void readdiary(void) {
    /*
     * fp:
     *   読み込み対象の日記ファイルを表す FILE *
     *
     * date:
     *   ユーザが指定する日付文字列（そのままファイル名になる）
     *
     * s:
     *   fp から fgets() で1行ずつ読み込むためのバッファ
     */
    FILE *fp;
    char date[MAXLINE], s[MAXLINE];

    /*
     * 読みたい日付を受け取る。
     */
    getstr("date (MMDD): ", date, sizeof(date));

    /*
     * 指定日付のファイルを読み込みモードで開く。
     *
     * 重要:
     *   元コードではここも fopen 失敗チェックが省略されている。
     *   実務では NULL チェックが必要である。
     */
    fp = fopen(date, "r");

    /*
     * while (fgets(s, sizeof(s), fp) != NULL)
     *
     * fp から1行ずつ読み込むループである。
     *
     * fgets() が成功した間は、1行が s に入る。
     * その行を fputs(s, stdout) でそのまま画面に出す。
     *
     * したがって、このループは
     *
     *   ファイル fp ----1行読む----> s ----1行書く----> stdout
     *
     * という中継になっている。
     *
     * これは linecp.c と同じく「一行ずつの読み書き」であるが、
     * 出力先がファイルではなく stdout になっている。
     */
    while (fgets(s, sizeof(s), fp) != NULL) {
        /*
         * 読んだ1行をそのまま標準出力へ出す。
         *
         * fgets() は改行込みで文字列を作るので、
         * fputs() するだけで元の行構造が保たれる。
         */
        fputs(s, stdout);
    }

    /*
     * ここへ来たということは、fgets(fp) が NULL を返したということである。
     *
     * その理由は
     *   - EOF に達した
     *   - エラーが起きた
     * のどちらかである。
     *
     * ここでは ferror(fp) を見て、
     * エラーかどうかを明示的に確認している。
     *
     * EOF そのものは「読み終わっただけ」なので異常ではない。
     */
    if (ferror(fp)) { /* エラー? */
        /*
         * ferror(fp)
         *
         * fp にエラーフラグが立っているかを調べる。
         *
         * もし true なら、fgets() が止まったのは単なる EOF ではなく、
         * 入出力異常によるものと判断できる。
         *
         * この場合は異常として扱う。
         */
        perror("fgets");
        exit(1);
    }

    /*
     * ここまで来て ferror(fp) が偽なら、
     * fgets() が止まった理由は通常の EOF と解釈できる。
     *
     * つまり「最後まで正常に読み終えた」ということになる。
     */

    /*
     * 読み込みファイルを閉じる。
     *
     * 読み込み専用ストリームなので、
     * 出力ストリームほど flush の重要性は無いが、
     * 資源解放のために fclose するのが基本である。
     */
    fclose(fp);
}
