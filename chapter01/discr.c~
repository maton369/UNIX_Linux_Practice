/*
 * このコードの主題は「弁別子付き共用体 (tagged union / discriminated union)」である。
 *
 * C の union は、複数の型を同じメモリ領域で共有できる一方で、
 * 「今その領域に何の型の値が入っているのか」を自分では覚えてくれない。
 *
 * そのため、union を安全に使うには、
 *   - 今の中身は int なのか
 *   - 今の中身は double なのか
 * を別の情報として管理する必要がある。
 *
 * その「今どの型が有効か」を表す情報が、ここでいう弁別子である。
 *
 * このコードでは
 *
 *   enum Type { Int, Double };
 *
 * が弁別子の役割を果たしている。
 *
 * つまり、
 *   x.type == Int    なら x.u.i が有効
 *   x.type == Double なら x.u.d が有効
 *
 * という約束で使う。
 *
 * このように
 *   「union本体」 + 「今どのメンバが有効かを示すタグ」
 * を組み合わせた構造は、C で非常によく使われる。
 *
 * 代表例:
 *   - 抽象構文木(AST)のノード
 *   - いろいろな種類の値を1つで表したいインタプリタ
 *   - イベント型ごとに内容が違うイベント構造体
 *   - メッセージ種別ごとにペイロードが違う通信データ
 *
 * 重要:
 *   union 単体では「どのメンバを読むべきか」は分からない。
 *   だからこそ、enum などの弁別子をセットで持つ必要がある。
 */

/*
 * union foo:
 *   int と double を同じメモリ領域で共有する共用体である。
 *
 * struct と違い、各メンバが別々の領域を持つのではなく、
 * 同じ領域を型を変えて見ている。
 *
 * そのため、
 *   u.i に書いた後に u.d を読む
 *   u.d に書いた後に u.i を読む
 * といった使い方は、意味的に危険である。
 *
 * union は「複数の候補のうち、同時に有効なのは1つだけ」
 * という場面で使うのが基本である。
 */
union foo {
    int i;      /* int 型の値として使うときの見方 */
    double d;   /* double 型の値として使うときの見方 */
};

/*
 * enum Type:
 *   union foo の中で「今どのメンバが有効なのか」を表す弁別子である。
 *
 * Int:
 *   union foo の中身は int として解釈すべきであることを表す。
 *
 * Double:
 *   union foo の中身は double として解釈すべきであることを表す。
 *
 * ここで大事なのは、
 *   enum Type は union の中身そのものではなく、
 *   union の中身をどう読むべきかの「説明ラベル」
 * だという点である。
 *
 * たとえるなら:
 *   union foo u; は「中身の入れ物」
 *   enum Type type; は「この入れ物には今何が入っているかのラベル」
 *
 * である。
 */
enum Type {
    Int,     /* u.i が有効であることを示す弁別子 */
    Double   /* u.d が有効であることを示す弁別子 */
};

/*
 * struct bar:
 *   弁別子付き共用体を実現する構造体である。
 *
 * メンバ:
 *   type : 今 union のどのメンバが有効かを表す弁別子
 *   u    : 実際の値を入れる共用体
 *
 * つまりこの struct は、
 *
 *   「値そのもの」だけでなく
 *   「その値の型情報」も一緒に持つ
 *
 * という設計になっている。
 *
 * これは型安全性を人力で補うための典型パターンである。
 *
 * イメージ:
 *
 *   struct bar x;
 *
 *   +-------------------+---------------------------+
 *   | type              | union foo u              |
 *   | (今の有効型)      | (実際の値の入れ物)       |
 *   +-------------------+---------------------------+
 *
 * 例えば:
 *   x.type = Double
 *   x.u.d  = 12.34
 *
 * であれば、
 *   「この値は double 型として読むべきだ」
 * と分かる。
 */
struct bar {
    enum Type type; /* 弁別子: union のどのメンバが現在有効かを示す */
    union foo u;    /* 実際の値を保持する共用体 */
};

int main(void)
{
    /*
     * struct bar 型の変数 x を定義する。
     *
     * x は
     *   - type という弁別子
     *   - u    という共用体
     * をまとめて持つ。
     *
     * この時点では、x.type も x.u もまだ明示的に初期化されていないので、
     * そのまま読んではいけない。
     *
     * 特に union は「最後にどのメンバへ書いたか」が重要なので、
     * 書き込む前に読むのは危険である。
     */
    struct bar x;

    /*
     * x.u.d = 12.34;
     *
     * これは、共用体領域 u に対して
     * 「double 型の値 12.34 を書き込む」処理である。
     *
     * つまりこの時点で、u の中身は
     *   int として有効
     * なのではなく、
     *   double として有効
     * だと考えるべき状態になっている。
     *
     * ただし、union 自体は
     *   「今 d が有効ですよ」
     * とは記録してくれない。
     *
     * だから、この代入だけではまだ安全な設計としては不十分である。
     * そこで次に弁別子 x.type を更新する必要がある。
     */
    x.u.d = 12.34;

    /*
     * x.type = Double;
     *
     * ここで弁別子を更新して、
     * 「x.u の中身は double として読むべきである」
     * という情報を明示している。
     *
     * これにより、後から別のコードが x を読むときに、
     *
     *   if (x.type == Double) {
     *       printf("%f\n", x.u.d);
     *   }
     *
     * のように、安全に「どの union メンバを読むべきか」を判断できる。
     *
     * つまり、この1行は単なる補助情報ではなく、
     * union を安全に使うための本質的な処理である。
     *
     * もしこれを書かなければ、
     * 後続のコードは
     *   x.u.i を読むべきか
     *   x.u.d を読むべきか
     * を判断できない。
     *
     * それは、union の危険な使い方につながる。
     */
    x.type = Double;

    /*
     * このサンプルでは値を書き込んで弁別子を設定したところで終了する。
     *
     * 実際には、この後に例えば次のような処理を書くと、
     * 弁別子付き共用体の意味がよりはっきりする。
     *
     *   if (x.type == Int) {
     *       printf("%d\n", x.u.i);
     *   } else if (x.type == Double) {
     *       printf("%f\n", x.u.d);
     *   }
     *
     * こうすると、
     *   type を見てから正しい union メンバを読む
     * という設計になる。
     *
     * これが弁別子付き共用体の基本的な使い方である。
     */

    return 0;
}
