/* proc/mysh4.c */
#include <sys/types.h>  /* pid_t 型, fork/open/wait に関連する型定義 */
#include <stdio.h>      /* feof, ferror, fputs, perror, stderr, stdin を使うためのヘッダ */
#include <stdlib.h>     /* exit を使うためのヘッダ */
#include <string.h>     /* strcmp を使うためのヘッダ */
#include <sys/stat.h>   /* open の mode 引数に関わる定義 */
#include <fcntl.h>      /* open, O_WRONLY, O_CREAT, O_TRUNC を使うためのヘッダ */
#include <sys/wait.h>   /* wait を使うためのヘッダ */
#include <unistd.h>     /* close, execvp, fork を使うためのヘッダ */
#include "mysub.h"
#include "myvec.h"

/*
 * このコードの主題は「簡易シェルにおける出力リダイレクト」である。
 *
 * 以前の簡易シェルでは、
 *   - コマンドラインを読む
 *   - fork() で子を作る
 *   - 子で execvp() する
 *   - 親で wait() する
 * という流れだけを扱っていた。
 *
 * この mysh4.c では、それに加えて
 *
 *   command > file
 *
 * のような「標準出力をファイルへ切り替える」機能を実装している。
 *
 * ここで重要なのは、
 *   「execvp() 自体にリダイレクト機能がある」のではなく、
 *   「execvp() を呼ぶ前に、子プロセスのファイルディスクリプタ 1
 *    （標準出力）を別ファイルへ結び直している」
 * という点である。
 *
 * つまりアルゴリズムとしては、
 *
 *   1. コマンドラインを argv に分解する
 *   2. ">" があるか探す
 *   3. あれば、その左側だけをコマンド引数として残す
 *   4. 右側のファイル名を outfile として覚える
 *   5. fork() で子を作る
 *   6. 子プロセスでは、もし outfile があれば
 *        - 標準出力( fd=1 )を閉じる
 *        - open(outfile, ...) で新しいファイルを開く
 *      すると、その open が fd=1 を再利用する
 *   7. その状態で execvp() を呼ぶ
 *   8. 新しいプログラムは「普通に標準出力へ出力しているつもり」で、
 *      実際には outfile に書くことになる
 *
 * となっている。
 *
 * これが UNIX におけるリダイレクトの本質である。
 *
 * つまりリダイレクトは
 *   「プログラムの出力先を特別扱いする」
 * のではなく、
 *   「標準出力という番号 1 のファイルディスクリプタが指す先を、
 *    あらかじめ差し替えてから exec する」
 * ことで実現する。
 */

enum {
    /*
     * コマンドライン分解後に扱う引数数の上限。
     *
     * av 配列は MAXARGV 要素を持ち、
     * strtovec() により
     *   引数列 + 終端 NULL
     * がここに入る想定である。
     */
    MAXARGV = 100,
};

int main(void) {
    /*
     * cmd:
     *   ユーザが1行入力したコマンドライン全体を格納するバッファ。
     *
     *   例:
     *     "ls -l"
     *     "ls > out.txt"
     *     "echo hello > log.txt"
     *
     * av:
     *   strtovec() によって作られる argv ベクタ。
     *
     *   例:
     *     cmd = "ls > out.txt"
     *   なら概念的に
     *     av[0] = "ls"
     *     av[1] = ">"
     *     av[2] = "out.txt"
     *     av[3] = NULL
     *   のようになる。
     *
     * outfile:
     *   リダイレクト先のファイル名を指すポインタ。
     *
     *   リダイレクト記号 ">" が無ければ NULL のまま。
     *   ">" があれば、その次のトークン（ファイル名）を指す。
     *
     * i:
     *   av の中を走査して ">" を探すためのループ変数。
     *
     * ac:
     *   引数個数に相当する値。
     *   strtovec() が終端 NULL を含めて返す設計なので、あとで ac-- して調整する。
     *
     * status:
     *   wait() が子プロセスの終了状態を書き込む先。
     *
     * cpid:
     *   fork() で作られた子プロセスの PID。
     */
    char cmd[1024];
    char *av[MAXARGV], *outfile;
    int i, ac, status;
    pid_t cpid;

    /*
     * 無限ループで、簡易シェルとして
     *   入力 -> 解析 -> fork -> 子で exec -> 親で wait
     * を繰り返す。
     *
     * 1回のループが 1 コマンド実行に対応する。
     */
    for (;;) {
        /*
         * プロンプト "@ " を表示し、1行のコマンドラインを読む。
         *
         * ここで入力されるのは、
         *   "ls"
         *   "ls -l"
         *   "ls > out.txt"
         * のような生の文字列全体である。
         */
        getstr("@ ", cmd, sizeof(cmd));

        /*
         * EOF ならシェルを正常終了する。
         *
         * たとえば端末で Ctrl-D を入力した場合がこれに相当する。
         */
        if (feof(stdin)) {
            exit(0);
        } else if (ferror(stdin)) {
            /*
             * 入力ストリームエラーなら異常終了する。
             */
            perror("getstr");
            exit(1);
        }

        /*
         * cmd をトークン列へ分解して av に入れる。
         *
         * たとえば
         *   "ls > out.txt"
         * なら概念的に
         *   av[0] = "ls"
         *   av[1] = ">"
         *   av[2] = "out.txt"
         *   av[3] = NULL
         * のようになる。
         *
         * 戻り値 ac は終端 NULL も含んだ個数として返る想定。
         */
        if ((ac = strtovec(cmd, av, MAXARGV)) > MAXARGV) {
            /*
             * 引数が多すぎる場合はこのコマンドを捨てる。
             */
            fputs("argument list too long\n", stderr);
            continue;
        }

        /*
         * 終端 NULL の分を除いて、実引数個数へ直す。
         *
         * 例:
         *   av = {"ls", ">", "out.txt", NULL}
         * なら ac は最初 4 とみなし、
         * ac-- 後は 3 になる。
         */
        ac--;

        /*
         * 空行なら何もしないで次のループへ進む。
         */
        if (ac == 0)    /* 入力なし */
            continue;

        /*
         * --------------------------------------------------------------
         * 出力リダイレクトの解析
         * --------------------------------------------------------------
         *
         * ここがこのコードの中心である。
         *
         * やりたいことは、
         *
         *   command arg1 arg2 > file
         *
         * のような入力から、
         *
         *   - 実際に execvp() に渡すコマンド引数列
         *   - リダイレクト先ファイル名
         *
         * を切り分けることである。
         *
         * アルゴリズムとしては次のようになる。
         *
         *   1. まず outfile = NULL にしておく
         *   2. av を左から順に見て ">" を探す
         *   3. 見つかったら
         *        av[i] = NULL にして argv をそこで終わらせる
         *        ac = i として実引数長もそこまでにする
         *        outfile = av[i+1] として出力ファイル名を覚える
         *   4. 見つからなければリダイレクトなし
         *
         * つまり ">" は
         *   「コマンド引数とシェル制御情報の境界」
         * を表す記号として使われている。
         */

        /*
         * まず「リダイレクトなし」を意味する NULL で初期化する。
         *
         * このあと ">" が見つかった場合だけ、
         * outfile がファイル名を指すようになる。
         */
        outfile = NULL;

        /*
         * av[0] から av[ac-1] まで順に見て、
         * リダイレクト記号 ">" を探す。
         */
        for (i = 0; i < ac; i++) {
            if (!strcmp(av[i], ">")) {
                /*
                 * av[i] が ">" と一致した、つまりここがリダイレクト記号である。
                 *
                 * ここからが最も重要な操作である。
                 */

                /*
                 * av[i] = NULL;
                 *
                 * これにより、execvp() から見た argv ベクタはここで終わる。
                 *
                 * たとえばもともと
                 *
                 *   av[0] = "ls"
                 *   av[1] = "-l"
                 *   av[2] = ">"
                 *   av[3] = "out.txt"
                 *   av[4] = NULL
                 *
                 * だったとすると、
                 *
                 *   av[2] = NULL
                 *
                 * に書き換えたあと、execvp() から見える引数列は
                 *
                 *   {"ls", "-l", NULL}
                 *
                 * になる。
                 *
                 * つまり ">" とその後ろのファイル名は、
                 * コマンドプログラムに渡す引数ではなく、
                 * シェル側が解釈して処理する制御情報になる。
                 *
                 * 図にすると:
                 *
                 *   変更前:
                 *     [ "ls" ][ "-l" ][ ">" ][ "out.txt" ][ NULL ]
                 *
                 *   変更後:
                 *     [ "ls" ][ "-l" ][ NULL ][ "out.txt" ][ NULL ]
                 *
                 * execvp() は最初の NULL で止まるので、
                 * 実際のコマンド引数は
                 *   "ls", "-l"
                 * だけになる。
                 */
                av[i] = NULL;           /* ここがコマンド引数の終わり */

                /*
                 * ac もコマンド引数部分だけの長さに更新する。
                 *
                 * このコードではこの後 ac を直接あまり使わないが、
                 * 論理的には「引数列の長さはここまで」という意味になる。
                 */
                ac = i;

                /*
                 * リダイレクト先のファイル名を覚える。
                 *
                 * ">" の次のトークンを outfile に入れている。
                 *
                 * たとえば
                 *   ls > out.txt
                 * なら
                 *   outfile = "out.txt"
                 *
                 * になる。
                 *
                 * コメントにある通り、
                 *   av[i+1]
                 * が NULL の可能性もある。
                 *
                 * つまり
                 *   ls >
                 * のようにファイル名を書かなかった場合、
                 * outfile は不正になる。
                 *
                 * このコードは教材として簡潔に書かれており、
                 * その検査はまだ省略されている。
                 * 実用的にはここを厳密にチェックしたい。
                 */
                outfile = av[i+1];      /* XXX: ヌルポインタかも */

                /*
                 * ">" より後ろのトークンは、この簡易実装では全部無視する。
                 *
                 * たとえば
                 *   ls > out.txt extra
                 * のような入力が来ても、
                 * out.txt より後ろは解析しない。
                 *
                 * ここでは最初に見つかった ">" 1個だけを扱う単純な実装である。
                 */
                /* （av の残りは無視される） */
                break;
            }
        }

        /*
         * --------------------------------------------------------------
         * fork() -> 子でリダイレクト設定 -> execvp()
         * --------------------------------------------------------------
         *
         * ここから実行フェーズに入る。
         *
         * 親はシェル本体として残り、
         * 子が実際のコマンド実行担当になる。
         */
        if ((cpid = fork()) == -1) {
            /*
             * fork 失敗時はエラーメッセージを出し、
             * このコマンドは諦めて次のループへ進む。
             *
             * 以前のコードでは exit していたが、
             * ここでは continue にしているので、
             * シェルとしては生き残ろうとする設計である。
             */
            perror("fork");
            continue;
        } else if (cpid == 0) {
            /* 子プロセス */

            /*
             * 子プロセス側でのみリダイレクト設定を行う。
             *
             * これが非常に重要である。
             *
             * なぜ子でやるのか:
             *   親シェル自身の標準出力を変えてしまうと、
             *   その後のプロンプトやエラー出力までファイルへ流れてしまう。
             *
             * したがって、
             *   「これから実行するコマンドだけ」の標準出力を差し替えたいなら、
             *   exec される直前の子プロセスでだけ fd=1 を差し替える
             * のが正しい。
             *
             * つまりリダイレクトは
             *   親ではなく子の実行環境を変更する操作
             * である。
             */
            if (outfile != NULL) {
                /*
                 * ------------------------------------------------------
                 * リダイレクトの核心
                 * ------------------------------------------------------
                 *
                 * ここでは次の2段階で標準出力をファイルへ結び直している。
                 *
                 *   1. close(1)
                 *      -> ファイルディスクリプタ 1（標準出力）を閉じる
                 *
                 *   2. open(outfile, O_WRONLY|O_CREAT|O_TRUNC, 0666)
                 *      -> 新しいファイルを開く
                 *
                 * UNIX のファイルディスクリプタ割当規則では、
                 * open() は「その時点で最小の未使用 fd」を返す。
                 *
                 * いま 1 を先に閉じているので、
                 * 次の open() は通常 fd=1 を返す。
                 *
                 * その結果、新しく開いた outfile が
                 * 「標準出力そのもの」になる。
                 *
                 * つまり、その後 execvp() されたプログラムが
                 *
                 *   printf(...)
                 *   write(1, ...)
                 *
                 * などで標準出力へ書くと、
                 * その内容は端末ではなく outfile に書かれる。
                 *
                 * これが UNIX のリダイレクトの本質である。
                 */

                /*
                 * close(1);
                 *
                 * 1 は標準出力 stdout に対応するファイルディスクリプタ番号である。
                 *
                 * これを閉じることで、
                 * 「fd=1 の席」を空ける。
                 *
                 * 図:
                 *
                 *   実行前の子:
                 *     fd 0 -> 標準入力
                 *     fd 1 -> 端末への標準出力
                 *     fd 2 -> 標準エラー
                 *
                 *   close(1) 後:
                 *     fd 0 -> 標準入力
                 *     fd 1 -> 空き
                 *     fd 2 -> 標準エラー
                 */
                close(1);               /* 標準出力を閉じる */

                /*
                 * open(outfile, O_WRONLY|O_CREAT|O_TRUNC, 0666)
                 *
                 * リダイレクト先ファイルを開く。
                 *
                 * フラグの意味:
                 *
                 *   O_WRONLY
                 *     書き込み専用で開く
                 *
                 *   O_CREAT
                 *     ファイルが無ければ新規作成する
                 *
                 *   O_TRUNC
                 *     すでに存在していれば長さを 0 にして中身を消す
                 *
                 * mode 0666 の意味:
                 *   新規作成時のパーミッション候補である。
                 *   実際の作成権限は umask の影響を受ける。
                 *
                 * 重要:
                 *   さきほど fd=1 を閉じているので、
                 *   open() は通常その最小空き番号 1 を再利用する。
                 *
                 * したがって、戻り値を明示的に dup2 しなくても、
                 * この単純な実装では open 結果がそのまま「新しい標準出力」になる。
                 *
                 * 図:
                 *
                 *   close(1) 後:
                 *     fd 1 -> 空き
                 *
                 *   open("out.txt", ...) 後:
                 *     fd 1 -> out.txt
                 *
                 * これにより、その後の execvp() で起動されたプログラムは
                 * 自分では何も知らないまま、
                 * 標準出力が out.txt に向いている状態で動き始める。
                 */
                if (open(outfile, O_WRONLY|O_CREAT|O_TRUNC, 0666) == -1) {
                    /*
                     * リダイレクト先ファイルを開けなかった場合のエラー処理。
                     *
                     * 例:
                     *   書き込み権限がない
                     *   ディレクトリが存在しない
                     *   outfile が NULL で不正
                     * など。
                     *
                     * perror(outfile) により、
                     *   out.txt: Permission denied
                     * のようにファイル名つきで理由を表示できる。
                     */
                    perror(outfile);
                    exit(1);
                }
            }

            /*
             * ここまで来た時点で、
             *
             *   outfile == NULL なら
             *     標準出力は元の端末のまま
             *
             *   outfile != NULL なら
             *     標準出力(fd=1) は outfile を指している
             *
             * 状態になっている。
             *
             * その状態で execvp(av[0], av) を呼ぶ。
             *
             * 重要:
             *   execvp はファイルディスクリプタ表を基本的に引き継ぐので、
             *   子がここで作った「fd=1 -> outfile」の状態は
             *   新しいプログラムにもそのまま受け継がれる。
             *
             * したがって、exec されたプログラムは
             *   「自分は標準出力へ出しているだけ」
             * のつもりでも、
             *   実際にはファイルへ書いている
             * ことになる。
             *
             * これがリダイレクトの成立理由である。
             */
            execvp(av[0], av);

            /*
             * ここへ来るのは execvp が失敗した場合だけである。
             *
             * たとえば
             *   コマンドが存在しない
             *   実行権限がない
             * など。
             */
            perror(cmd);
            exit(1);
        }

        /* 親プロセス */

        /*
         * 親プロセスはシェル本体として残る。
         *
         * このコードではバックグラウンド実行はまだ扱っていないので、
         * 毎回 wait(&status) により
         *   「今起動した子が終わるまで待つ」
         * という前面実行型の挙動になる。
         *
         * つまり mysh4 の新要素はリダイレクトであり、
         * 実行制御自体は前面実行のままである。
         */
        if (wait(&status) == (pid_t)-1) {
            /*
             * wait 失敗時はシェル自身を異常終了させる。
             */
            perror("wait");
            exit(1);
        }

        /*
         * wait が成功したら、その子プロセスは終了し、終了状態も回収された。
         * その後、ループ先頭に戻って次のプロンプトを出す。
         *
         * したがってこのシェルは
         *   1コマンドずつ前面実行し、
         *   そのコマンドの標準出力だけを必要に応じてファイルへ切り替える
         * という挙動になる。
         */
    }

    /*
     * for(;;) 無限ループなので通常ここへは到達しない。
     * 構文上の終了点として書かれている。
     */
    exit(0);
}
