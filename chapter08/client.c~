/* socket/client.c */
#include <sys/types.h>  /* connect, inet_addr, read, socket, write に関係する型定義 */
#include <sys/socket.h> /* socket, connect, shutdown, AF_INET, SOCK_STREAM を使うためのヘッダ */
#include <stdio.h>      /* fprintf, perror を使うためのヘッダ */
#include <stdlib.h>     /* exit を使うためのヘッダ */
#include <string.h>     /* memset を使うためのヘッダ */
#include <netinet/in.h> /* struct sockaddr_in を使うためのヘッダ */
#include <arpa/inet.h>  /* htons, inet_addr を使うためのヘッダ */
#include <sys/uio.h>    /* read, write の宣言が入ることがある */
#include <unistd.h>     /* read, write, close を使うためのヘッダ */

#define SERVER_ADDR     "127.0.0.1"
#define SERVER_PORT     12345

/*
 * このプログラムの主題は、
 *
 *   「TCP クライアントとしてサーバへ接続し、
 *    サーバから送られてくるデータを受信して標準出力へ表示する」
 *
 * ことである。
 *
 * つまり役割としては「受信側クライアント」であり、
 * 処理の大きな流れは次のようになる。
 *
 *   1. socket() で通信のためのソケットを作る
 *   2. sockaddr_in で接続先アドレスとポート番号を表現する
 *   3. connect() でサーバへ接続する
 *   4. read() でサーバから届くバイト列を読む
 *   5. write() でその内容を画面へ出す
 *   6. 通信終了後に shutdown() と close() で後始末する
 *
 * このコードで特に重要なのは、
 * 「ソケット通信におけるシステムコールが何を意味するか」
 * を順番に追うことである。
 *
 * 通常ファイルでは
 *
 *   open() -> read()/write() -> close()
 *
 * という流れになるが、
 * ソケット通信では TCP クライアントの場合、
 *
 *   socket() -> connect() -> read()/write() -> shutdown()/close()
 *
 * という流れになる。
 *
 * つまりソケットも file descriptor の一種であり、
 * 接続が確立した後は read()/write() でバイトストリームとして扱える。
 *
 * これが UNIX 的な重要ポイントである。
 */

int main(void) {
    /*
     * s:
     *   socket() が返すソケットのファイルディスクリプタである。
     *
     *   通常ファイルを open() したときに返る fd と同じく、
     *   これは「カーネル内の通信端点」を指す整数番号である。
     *
     *   以後、
     *     connect(s, ...)
     *     read(s, ...)
     *     shutdown(s, ...)
     *     close(s)
     *   のように、この s を通して通信を制御する。
     *
     * cc:
     *   read() が実際に読み込んだバイト数を保持する変数である。
     *
     *   read() の戻り値は
     *     > 0 : 読み込めたバイト数
     *       0 : EOF（相手が送信を終えた）
     *      -1 : エラー
     *   を意味する。
     *
     * sa:
     *   接続先サーバのアドレス情報を入れる構造体である。
     *
     *   sockaddr_in は「IPv4 用のアドレス構造体」であり、
     *   中には
     *     - アドレスファミリ (AF_INET)
     *     - ポート番号
     *     - IP アドレス
     *   などを入れる。
     *
     * buf:
     *   サーバから受信したデータを一時的に保存するバッファ。
     *
     *   今回は 1024 バイト単位で受信している。
     */
    int s, cc;
    struct sockaddr_in sa;
    char buf[1024];

    /*
     * ------------------------------------------------------------
     * 1. socket() でソケットを作る
     * ------------------------------------------------------------
     *
     * socket(AF_INET, SOCK_STREAM, 0)
     *
     * これは「まだ接続先が決まっていない通信端点」をカーネルに作らせる
     * システムコールである。
     *
     * 各引数の意味:
     *
     *   第1引数 AF_INET:
     *     IPv4 通信を使うことを表す。
     *
     *     AF は Address Family の略であり、
     *     ここでは IPv4 アドレス体系
     *     （例: 127.0.0.1 や 192.168.1.10 など）
     *     を使うことを指定している。
     *
     *   第2引数 SOCK_STREAM:
     *     ストリーム型ソケットを使うことを表す。
     *
     *     これは通常 TCP を意味すると考えてよい。
     *     特徴は
     *       - 接続指向
     *       - 順序保証あり
     *       - バイトストリーム
     *     である。
     *
     *     つまり send/receive は「メッセージ単位」ではなく
     *     「バイトの流れ」として扱われる。
     *
     *   第3引数 0:
     *     通常はデフォルトのプロトコルを使う。
     *
     *     AF_INET + SOCK_STREAM の組み合わせでは、
     *     実質的に TCP が選ばれる。
     *
     * 戻り値:
     *   成功時:
     *     新しいソケット fd を返す
     *
     *   失敗時:
     *     -1 を返す
     *
     * 失敗理由の例:
     *   - ソケット資源不足
     *   - ファイルディスクリプタ上限
     *   - カーネル資源不足
     *
     * アルゴリズムとしては、ここが
     *
     *   「通信のための窓口を作る」
     *
     * フェーズである。
     *
     * 重要:
     *   この時点ではまだサーバとはつながっていない。
     *   ただ「TCP 通信用のソケット fd が1つできた」だけである。
     */
    if ((s = socket(AF_INET, SOCK_STREAM, 0)) == -1) {
        perror("socket");
        exit(1);
    }

    /*
     * ------------------------------------------------------------
     * 2. 接続先アドレス情報を sockaddr_in に詰める
     * ------------------------------------------------------------
     *
     * connect() を呼ぶには、
     * 「どの IP アドレスの、どのポート番号へ接続したいか」
     * を sockaddr 構造体で渡す必要がある。
     *
     * 今回は IPv4 用なので sockaddr_in を使う。
     */

    /*
     * memset(&sa, 0, sizeof(sa));
     *
     * 構造体 sa 全体を 0 で初期化する。
     *
     * 理由:
     *   sockaddr_in には使用するフィールド以外にも余白や予約領域があり、
     *   そこにゴミ値が入っていると挙動が不安定になる可能性があるため。
     *
     * まず全体をゼロクリアしてから、
     * 必要な項目だけを埋めるのが定石である。
     */
    memset(&sa, 0, sizeof(sa));

    /*
     * sa.sin_len = sizeof(sa);
     *
     * これは BSD 系にある実装向けのフィールドで、
     * sockaddr 構造体全体の長さを表す。
     *
     * Linux では存在しない環境もあるため、
     * この行は「sin_len がある場合」というコメント付きになっている。
     *
     * つまり、このコードは一部環境差異を意識した書き方になっている。
     */
    sa.sin_len = sizeof(sa);            /* sin_len がある場合 */

    /*
     * sa.sin_family = AF_INET;
     *
     * このアドレスが IPv4 用であることを示す。
     *
     * socket() 側でも AF_INET を指定しているので、
     * ここでも同じアドレスファミリを指定して整合を取る。
     */
    sa.sin_family = AF_INET;

    /*
     * sa.sin_port = htons(SERVER_PORT);
     *
     * 接続先ポート番号を設定する。
     *
     * SERVER_PORT は 12345 である。
     *
     * ただし、そのまま整数を代入するのではなく、
     * htons() を通している点が重要である。
     *
     * htons:
     *   host to network short
     *
     * の略であり、
     * ホストバイトオーダ（CPU ネイティブ）から
     * ネットワークバイトオーダ（ビッグエンディアン）へ変換する関数である。
     *
     * TCP/IP ヘッダや sockaddr では、
     * 数値はネットワークバイトオーダで入れる必要がある。
     *
     * そのため port は htons() が必要になる。
     *
     * 一言でいうと、
     *   「ポート番号をネットワークで通用する並びに変換している」
     * という意味である。
     */
    sa.sin_port = htons(SERVER_PORT);

    /*
     * sa.sin_addr.s_addr = inet_addr(SERVER_ADDR);
     *
     * 接続先の IPv4 アドレスを設定する。
     *
     * SERVER_ADDR は "127.0.0.1" なので、
     * 接続先はローカルホスト（同一マシン上のサーバ）である。
     *
     * inet_addr():
     *   ドット区切り文字列形式の IPv4 アドレス
     *   例: "127.0.0.1"
     *   を、ネットワークバイトオーダの 32bit 整数へ変換する関数である。
     *
     * つまりここでは
     *   "127.0.0.1"
     * を
     *   sockaddr_in に入れられる内部表現
     * に変換している。
     *
     * これで sa は
     *
     *   IPv4, port 12345, address 127.0.0.1
     *
     * を表す構造体になる。
     */
    sa.sin_addr.s_addr = inet_addr(SERVER_ADDR);

    /*
     * ------------------------------------------------------------
     * 3. connect() でサーバへ接続する
     * ------------------------------------------------------------
     *
     * ここで、先ほど作ったソケット s を、
     * sa で表されたサーバへ接続する。
     *
     * connect() は TCP クライアント側で非常に重要なシステムコールである。
     *
     * 意味としては、
     *   「このソケットを、指定した相手先アドレスへ接続済み状態にする」
     * である。
     *
     * TCP の内部的にはここで、
     *   - 宛先 IP / ポートを決める
     *   - TCP の接続確立手順（3-way handshake）を行う
     * といったことがカーネル内部で進む。
     *
     * つまり socket() が「電話機を用意する」なら、
     * connect() は「相手に発信して通話状態にする」に近い。
     */
    fprintf(stderr, "Connecting to the server...\n");

    /*
     * connect(s, (struct sockaddr *)&sa, sizeof(sa))
     *
     * 第1引数:
     *   s
     *   -> 接続に使うソケット fd
     *
     * 第2引数:
     *   (struct sockaddr *)&sa
     *   -> 接続先アドレス
     *
     *   connect() の一般形は struct sockaddr* を取るため、
     *   sockaddr_in* をキャストして渡している。
     *
     * 第3引数:
     *   sizeof(sa)
     *   -> アドレス構造体のサイズ
     *
     * 戻り値:
     *   成功時:
     *     0
     *
     *   失敗時:
     *     -1
     *
     * 失敗理由の例:
     *   - 相手が起動していない
     *   - 指定ポートで listen していない
     *   - ネットワーク到達不能
     *   - 接続拒否 (Connection refused)
     *
     * connect() に成功すると、
     * このソケット s は「接続済みソケット」になる。
     *
     * するとその後は
     *
     *   read(s, ...)
     *   write(s, ...)
     *
     * で通信できるようになる。
     *
     * これが TCP クライアントの基本形である。
     */
    if (connect(s, (struct sockaddr *)&sa, sizeof(sa)) == -1) {
        perror("connect");
        exit(1);
    }
    fprintf(stderr, "Connected.\n");

    /*
     * ------------------------------------------------------------
     * 4. read() でサーバから届くデータを受信する
     * ------------------------------------------------------------
     *
     * connect() に成功すると、
     * ソケット s は接続済みストリームとして使える。
     *
     * そのため通常ファイルと同じように read()/write() が使える。
     *
     * ただし重要なのは、TCP は「バイトストリーム」であり、
     * メッセージ境界を保持しないことだ。
     *
     * つまりサーバが1回 write() した内容が、
     * クライアントで1回の read() にちょうど対応するとは限らない。
     *
     * そのためこのコードでは while ループで
     * 「届く限り繰り返し読む」形にしている。
     */
    fprintf(stderr, "Message from the server:\n\n");

    /*
     * while ((cc = read(s, buf, sizeof(buf))) > 0)
     *
     * ソケット s から最大 1024 バイトずつ読む。
     *
     * read() の戻り値:
     *   cc > 0:
     *     実際に読めたバイト数
     *
     *   cc == 0:
     *     EOF
     *     -> 相手が送信を終了し、もうこれ以上データが来ない
     *
     *   cc == -1:
     *     エラー
     *
     * TCP ソケットはストリームなので、
     * 受信側は
     *
     *   「必要なだけ read() を繰り返して全部読む」
     *
     * という発想が基本になる。
     */
    while ((cc = read(s, buf, sizeof(buf))) > 0)
        /*
         * write(1, buf, cc);
         *
         * 受信した cc バイトをそのまま標準出力へ書く。
         *
         * 1 は STDOUT_FILENO と同じ意味であり、通常は端末画面である。
         *
         * ここで printf ではなく write を使っている理由は、
         * buf が C 文字列として '\0' 終端されている保証がないからである。
         *
         * read() は生バイト列を返すので、
         * 受信した長さ cc をそのまま write() に渡すのが安全である。
         *
         * つまりここは、
         *   「サーバから届いたデータをそのまま画面へ中継する」
         * 処理である。
         */
        write(1, buf, cc);

    /*
     * ループを抜けたあと、
     * cc == 0 なら正常に受信完了、
     * cc == -1 なら read エラーである。
     */
    if (cc == -1) {
        perror("read");
        exit(1);
    }
    fprintf(stderr, "\n\nFinished receiving.\n");

    /*
     * ------------------------------------------------------------
     * 5. shutdown() で通信を停止する
     * ------------------------------------------------------------
     *
     * shutdown(s, SHUT_RDWR)
     *
     * これはソケット通信を段階的に停止するためのシステムコールである。
     *
     * close() は「fd を閉じる」操作だが、
     * shutdown() は「送受信のどちらを止めるか」を指定できる。
     *
     * SHUT_RDWR:
     *   読み取り方向も書き込み方向も両方止める
     *
     * 他にも
     *   SHUT_RD  : 受信だけ止める
     *   SHUT_WR  : 送信だけ止める
     * がある。
     *
     * このコードでは読み取りも書き込みももう不要なので、
     * 両方止めている。
     *
     * つまり shutdown() は
     *
     *   「このソケットではもう通信しない」
     *
     * とカーネルへ明示的に伝える操作である。
     *
     * なお、単純なクライアントでは close() だけでも十分な場合は多いが、
     * shutdown() は通信方向を明確に制御したいときに重要になる。
     */
    if (shutdown(s, SHUT_RDWR) == -1) {
        perror("shutdown");
        exit(1);
    }

    /*
     * ------------------------------------------------------------
     * 6. close() でソケット fd 自体を閉じる
     * ------------------------------------------------------------
     *
     * shutdown() が通信の停止なら、
     * close() はファイルディスクリプタ資源の解放である。
     *
     * つまり役割を分けると、
     *
     *   shutdown():
     *     通信路としての送受信を終える
     *
     *   close():
     *     このプロセスが持っている fd 番号を解放する
     *
     * という違いがある。
     *
     * 通常のプログラム終了時には最終的に close() が必要である。
     */
    if (close(s) == -1) {
        perror("close");
        exit(1);
    }

    /*
     * ここまで来たということは、
     *   - ソケット作成に成功した
     *   - 接続に成功した
     *   - サーバからのデータを最後まで受信した
     *   - shutdown と close に成功した
     *
     * ということなので、正常終了する。
     */
    return 0;
}
