#include <stdio.h>   /* printf を使うためのヘッダ */
#include <stdarg.h>  /* 可変長引数を扱うためのマクロ群
                      *   va_list
                      *   va_start
                      *   va_arg
                      *   va_end
                      * を定義している
                      */

/*
 * このコードの主題は「可変長引数 (variadic arguments)」である。
 *
 * 可変長引数とは、
 *   関数に渡す引数の個数が呼び出しごとに変わる仕組み
 * である。
 *
 * 代表例:
 *   printf("%d %s\n", 10, "hello");
 *
 * printf は書式文字列の内容に応じて、
 * その後ろに続く引数の個数や型が変わる。
 * こうした「固定個数ではない引数」を扱うのが可変長引数である。
 *
 * C 言語では、可変長引数を直接 for 文でたどれるわけではない。
 * そのため <stdarg.h> に用意された仕組みを使って、
 * 「可変長部分を順番に読む」必要がある。
 *
 * このコードでは add(arg_num, ...) という関数を定義し、
 *
 *   add(0)
 *   add(1, 10)
 *   add(2, 10, 20)
 *   add(3, 10, 20, 30)
 *
 * のように、個数の異なる整数列を受け取って合計する。
 *
 * 重要な考え方:
 *   可変長引数では、関数側は「何個あるか」を自動では知らない。
 *   そのため、このコードでは
 *
 *     int arg_num
 *
 * を先頭に置き、
 * 「後ろに何個の int が続くか」を呼び出し側が明示している。
 *
 * つまりこの関数は、
 *
 *   最初の引数 arg_num = 可変長部分に何個あるかの説明
 *   残りの引数         = 実際の加算対象
 *
 * という約束で動いている。
 */

/*
 * add:
 *   可変個の int 値を受け取り、その総和を返す関数である。
 *
 * 引数:
 *   arg_num
 *     可変長部分に何個の int があるかを示す個数情報
 *
 *   ...
 *     実際の可変長引数列
 *
 * たとえば
 *
 *   add(3, 10, 20, 30)
 *
 * の場合、
 *
 *   arg_num = 3
 *   可変長部分 = 10, 20, 30
 *
 * となる。
 *
 * この関数のアルゴリズムは次の通りである。
 *
 *   1. 可変長引数走査の準備をする
 *   2. arg_num 回だけ繰り返す
 *   3. そのたびに次の int を取り出して sum に加える
 *   4. 後始末をする
 *   5. 合計値を返す
 */
int add(int arg_num, ...)
{
    /*
     * i:
     *   ループ回数を数えるための変数
     *
     * sum:
     *   受け取った整数群の合計を保持する変数
     *   最初は 0 から開始する
     */
    int i, sum = 0;

    /*
     * va_list pvar;
     *
     * va_list は「今どこまで可変長引数を読み進めたか」を表すための
     * 管理用オブジェクトである。
     *
     * 実体は環境依存だが、概念的には
     *
     *   「可変長引数列を順番に読むためのカーソル」
     *
     * のようなものだと考えるとよい。
     *
     * pvar という名前は任意であり、ここでは
     *   parameter variable
     * のような感覚で使っているだけである。
     */
    va_list pvar;

    /*
     * va_start(pvar, arg_num);
     *
     * これにより、pvar を「可変長引数の先頭」に初期化する。
     *
     * 第2引数 arg_num は、
     * 「固定引数の最後の引数」を指定する。
     *
     * つまりこの関数定義
     *
     *   int add(int arg_num, ...)
     *
     * において、可変長部分の直前にある固定引数は arg_num なので、
     * va_start の第2引数にも arg_num を渡す。
     *
     * これを行うと、内部的には
     * 「arg_num の次に並んでいる可変長引数群」を
     * 順に読める状態になる。
     *
     * イメージ:
     *
     *   add(3, 10, 20, 30)
     *
     *   固定引数:
     *     arg_num = 3
     *
     *   可変長引数:
     *     10, 20, 30
     *
     *   va_start 後の pvar:
     *     最初の可変長引数 10 を読む準備ができた状態
     */
    va_start(pvar, arg_num);

    /*
     * for (i = 0; i < arg_num; i++)
     *
     * arg_num 回だけループする。
     *
     * ここが非常に重要である。
     * 可変長引数には
     *   「何個あるか」
     * を自動判定する仕組みは基本的にない。
     *
     * したがって、この関数は
     *   arg_num の値を信じて
     * ちょうどその回数だけ va_arg で読み出している。
     *
     * もし arg_num が実際の個数と一致しなければ危険である。
     *
     * 例:
     *   add(3, 10, 20)   // 本当は2個しかないのに3個読む
     *
     * のような呼び出しをすると、
     * 存在しない引数まで読もうとして未定義動作になる。
     *
     * 逆に
     *
     *   add(1, 10, 20, 30)
     *
     * なら 10 だけ読んで終わり、残りは無視される。
     *
     * つまり、この関数の正しさは
     *   arg_num と実際の引数個数が一致している
     * という呼び出し側の約束に依存している。
     */
    for (i = 0; i < arg_num; i++) {

        /*
         * va_arg(pvar, int)
         *
         * pvar が現在指している「次の可変長引数」を
         * int 型として取り出す。
         *
         * そして取り出したあと、pvar は次の引数位置へ進む。
         *
         * つまりこの1行は概念的には
         *
         *   1. 現在位置の引数を読む
         *   2. それを int として解釈する
         *   3. 次へ進む
         *
         * という処理である。
         *
         * このコードでは、その取り出した値を sum に加算している。
         *
         * たとえば
         *
         *   add(3, 10, 20, 30)
         *
         * の場合、ループの各回で
         *
         *   1回目: va_arg(...) = 10
         *   2回目: va_arg(...) = 20
         *   3回目: va_arg(...) = 30
         *
         * となる。
         *
         * 注意:
         *   可変長引数では「型」を正しく指定する必要がある。
         *   ここで int と書いているのは、
         *   呼び出し側が int を渡している前提だからである。
         *
         *   もし実際には double を渡しているのに int として読んだりすると、
         *   値は壊れ、未定義動作になる。
         *
         * さらに重要な補足:
         *   可変長引数では「デフォルト引数昇格」が起きる。
         *   たとえば
         *     char, short → int に昇格
         *     float       → double に昇格
         *   する。
         *
         *   そのため、va_arg で読む型は
         *   「呼び出し側が最終的に渡される型」に合わせる必要がある。
         */
        sum += va_arg(pvar, int);
    }

    /*
     * va_end(pvar);
     *
     * 可変長引数処理の後始末を行う。
     *
     * 環境によっては実質何もしない場合もあるが、
     * 規約上、va_start を使ったなら対応する va_end を呼ぶ必要がある。
     *
     * これにより、
     *   「pvar を使った可変長引数走査はここで終わり」
     * ということを明示する。
     *
     * 可変長引数処理では、
     *   va_start
     *   ...
     *   va_arg
     *   ...
     *   va_end
     * というセットで書くのが基本である。
     */
    va_end(pvar);

    /*
     * ループで集計した合計値を返す。
     *
     * 例:
     *   add(0)             -> 0
     *   add(1, 10)         -> 10
     *   add(2, 10, 20)     -> 30
     *   add(3, 10, 20, 30) -> 60
     */
    return sum;
}

int main(void)
{
    /*
     * ここでは add 関数を4通り呼び出している。
     *
     * 1. add(0)
     *    可変長引数が 0 個なので、ループは 0 回で sum は 0 のまま
     *
     * 2. add(1, 10)
     *    可変長引数は 10 の 1 個だけなので、結果は 10
     *
     * 3. add(2, 10, 20)
     *    10 + 20 = 30
     *
     * 4. add(3, 10, 20, 30)
     *    10 + 20 + 30 = 60
     *
     * printf によって、これら4つの結果をまとめて表示している。
     *
     * 典型的な出力:
     *
     *   0, 10, 30, 60
     *
     * この main の役割は、
     *   「arg_num に応じて、可変長引数を何個読むかが変わる」
     * ことを確認するテストでもある。
     */
    printf("%d, %d, %d, %d\n",
           add(0),
           add(1, 10),
           add(2, 10, 20),
           add(3, 10, 20, 30));

    return 0;
}

/*
 * このコードから学ぶべき要点まとめ
 *
 * 1. 可変長引数では、関数は引数個数を自動では知らない
 *
 *    そのため、このコードでは arg_num という固定引数で
 *    「後ろにいくつ続くか」を明示している。
 *
 * 2. 可変長引数を扱うには <stdarg.h> の仕組みを使う
 *
 *    - va_list  : 走査用オブジェクト
 *    - va_start : 走査開始
 *    - va_arg   : 1個取り出す
 *    - va_end   : 後始末
 *
 * 3. va_arg では型を正しく指定しなければならない
 *
 *    このコードは int を読む前提で書かれている。
 *
 * 4. arg_num と実際の引数数が一致しないと危険
 *
 *    多すぎても少なすぎても問題になる。
 *    特に「足りないのに読む」場合は未定義動作になる。
 *
 * 5. 可変長引数は柔軟だが型安全ではない
 *
 *    そのため実務では、
 *    - 個数を別引数で渡す
 *    - 終端マーカーを使う
 *    - 書式文字列で型情報を与える
 *    などの方法で補助情報を持たせることが多い。
 *
 *
 * 図でまとめると:
 *
 *   add(3, 10, 20, 30)
 *
 *   固定引数:
 *     arg_num = 3
 *
 *   可変長引数列:
 *     10 -> 20 -> 30
 *
 *   va_start 後:
 *     pvar が 10 を読む位置にある
 *
 *   1回目 va_arg:
 *     10 を読む, sum = 10
 *
 *   2回目 va_arg:
 *     20 を読む, sum = 30
 *
 *   3回目 va_arg:
 *     30 を読む, sum = 60
 *
 *   va_end:
 *     後始末
 *
 *   return 60
 *
 *
 * このコードの本質を一言で言うと、
 *
 *   「固定引数 arg_num を手がかりに、可変長引数列から int を順番に取り出して合計している」
 *
 * である。
 */
